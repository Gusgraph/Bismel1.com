a:14:{s:7:"attribs";a:4:{s:5:"xmlns";s:36:"http://pear.php.net/dtd/rest.release";s:9:"xmlns:xsi";s:41:"http://www.w3.org/2001/XMLSchema-instance";s:11:"xmlns:xlink";s:28:"http://www.w3.org/1999/xlink";s:18:"xsi:schemaLocation";s:81:"http://pear.php.net/dtd/rest.release     http://pear.php.net/dtd/rest.release.xsd";}s:1:"p";a:2:{s:7:"attribs";a:1:{s:10:"xlink:href";s:12:"/rest/p/grpc";}s:8:"_content";s:4:"grpc";}s:1:"c";s:12:"pecl.php.net";s:1:"v";s:5:"0.5.0";s:2:"st";s:5:"alpha";s:1:"l";s:3:"BSD";s:1:"m";s:13:"stanleycheung";s:1:"s";s:89:"A high performance, open source, general RPC framework that puts mobile and HTTP/2 first.";s:1:"d";s:335:"Remote Procedure Calls (RPCs) provide a useful abstraction for building distributed applications and services. The libraries in this repository provide a concrete implementation of the gRPC protocol, layered over HTTP/2. These libraries enable communication between clients and servers using any combination of the supported languages.";s:2:"da";s:19:"2015-06-25 23:22:39";s:1:"n";s:19:"First alpha release";s:1:"f";s:5:"16699";s:1:"g";s:35:"https://pecl.php.net/get/grpc-0.5.0";s:1:"x";a:1:{s:7:"attribs";a:1:{s:10:"xlink:href";s:17:"package.0.5.0.xml";}}}