a:14:{s:7:"attribs";a:4:{s:5:"xmlns";s:36:"http://pear.php.net/dtd/rest.release";s:9:"xmlns:xsi";s:41:"http://www.w3.org/2001/XMLSchema-instance";s:11:"xmlns:xlink";s:28:"http://www.w3.org/1999/xlink";s:18:"xsi:schemaLocation";s:81:"http://pear.php.net/dtd/rest.release     http://pear.php.net/dtd/rest.release.xsd";}s:1:"p";a:2:{s:7:"attribs";a:1:{s:10:"xlink:href";s:12:"/rest/p/grpc";}s:8:"_content";s:4:"grpc";}s:1:"c";s:12:"pecl.php.net";s:1:"v";s:6:"1.14.1";s:2:"st";s:6:"stable";s:1:"l";s:10:"Apache 2.0";s:1:"m";s:13:"stanleycheung";s:1:"s";s:89:"A high performance, open source, general RPC framework that puts mobile and HTTP/2 first.";s:1:"d";s:335:"Remote Procedure Calls (RPCs) provide a useful abstraction for building distributed applications and services. The libraries in this repository provide a concrete implementation of the gRPC protocol, layered over HTTP/2. These libraries enable communication between clients and servers using any combination of the supported languages.";s:2:"da";s:19:"2018-08-09 20:42:49";s:1:"n";s:41:"- gRPC C Core patch release 1.14.1 uptake";s:1:"f";s:7:"2556684";s:1:"g";s:36:"https://pecl.php.net/get/grpc-1.14.1";s:1:"x";a:1:{s:7:"attribs";a:1:{s:10:"xlink:href";s:18:"package.1.14.1.xml";}}}